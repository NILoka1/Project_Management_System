{
  "name": "tracker-client",
  "version": "1.0.0",
  "description": "Tracker App - Client & Desktop",
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:client\" \"pnpm:dev:desktop\" --names \"VITE,ELECTRON\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail",
    "dev:client": "vite src/client --port 3000 --open",
    "dev:desktop": "cross-env NODE_ENV=development concurrently \"pnpm:electron:build\" \"pnpm:electron:start\" --names \"TSC,ELECTRON\" --prefix-colors \"yellow,magenta.bold\" --kill-others-on-fail",
    "electron:build": "tsc -p tsconfig.json --outDir dist/desktop",
    "electron:start": "wait-on dist/desktop/main.js && electron dist/desktop/main.js --inspect=5858",
    "build": "pnpm build:client && pnpm build:electron",
    "build:client": "vite build src/client",
    "build:electron": "tsc -p tsconfig.json --outDir dist/desktop",
    "dist": "pnpm build:client && pnpm build:electron && electron-builder --win",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:portable": "pnpm build && electron-builder --win portable",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:linux": "pnpm build && electron-builder --linux",
    "release": "pnpm dist",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --config eslint.config.cjs",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --config eslint.config.cjs --fix",
    "format": "prettier --write src/**/*.{ts,tsx,js,jsx,json,css,scss,md}",
    "test": "jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/charts": "^8.3.7",
    "@mantine/core": "^8.3.7",
    "@mantine/dates": "^8.3.7",
    "@mantine/form": "^8.3.7",
    "@mantine/hooks": "^8.3.7",
    "@mantine/modals": "^8.3.7",
    "@mantine/notifications": "^8.3.7",
    "@tabler/icons-react": "^3.35.0",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.2.2",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.tracker.app",
    "productName": "Tracker App",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "!dist/desktop/**/*.ts",
      "!dist/desktop/**/*.ts.map",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "dist/client",
        "to": "app",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    }
  }
}
