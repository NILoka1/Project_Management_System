{
  "name": "coursework2",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:server\" \"pnpm:dev:client\"",
    "dev:server": "nodemon src/server/index.js",
    "dev:client": "vite src/client --port 3000",
    "dev:desktop": "electron src/desktop/main.ts",
    "build": "pnpm build:server && pnpm build:client && pnpm build:desktop",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build src/client",
    "build:desktop": "tsc -p tsconfig.desktop.json && electron-builder",
    "db:generate": "prisma generate --schema=./packages/database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=./packages/database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./packages/database/prisma/schema.prisma"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/charts": "^8.3.7",
    "@mantine/core": "^8.3.7",
    "@mantine/dates": "^8.3.7",
    "@mantine/form": "^8.3.7",
    "@mantine/hooks": "^8.3.7",
    "@mantine/modals": "^8.3.7",
    "@mantine/notifications": "^8.3.7",
    "@prisma/client": "^6.19.0",
    "@tabler/icons-react": "^3.35.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "electron": "^39.1.2",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
