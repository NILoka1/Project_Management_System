{
  "name": "coursework2",
  "version": "1.0.0",
  "description": "",
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:client\" \"pnpm:dev:desktop\" --names \"VITE,ELECTRON\" --prefix-colors \"cyan.bold,magenta.bold\" --kill-others-on-fail",
    "dev:client": "vite src/client --port 3000 --open",
    "dev:desktop": "concurrently \"pnpm:tsc:watch\" \"pnpm:electron:start\" --kill-others --names \"TSC,ELECTRON\" --prefix-colors \"yellow,magenta\"",
    "tsc:watch": "tsc -p tsconfig.desktop.json --watch --preserveWatchOutput",
    "electron:start": "wait-on dist/desktop/main.js && electron dist/desktop/main.js --inspect=5858",
    "build:client": "vite build",
    "build:desktop": "tsc -p tsconfig.desktop.json",
    "dist": "pnpm build:client && pnpm build:desktop && electron-builder --win --config electron-builder.yml",
    "release": "pnpm dist",
    "build": "pnpm build:client && pnpm build:desktop",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/charts": "^8.3.7",
    "@mantine/core": "^8.3.7",
    "@mantine/dates": "^8.3.7",
    "@mantine/form": "^8.3.7",
    "@mantine/hooks": "^8.3.7",
    "@mantine/modals": "^8.3.7",
    "@mantine/notifications": "^8.3.7",
    "@prisma/client": "^6.19.0",
    "@tabler/icons-react": "^3.35.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/electron": "^1.6.12",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "wait-on": "^9.0.3"
  }
}
